# Copy to .env.deploy and fill in. Used by docker-compose.deploy.yml.
# Keep .env.deploy out of git (it holds the shared token).

# Shared secret every client must send as: Authorization: Bearer <token>
# Generate a strong one, e.g.:  openssl rand -hex 32   (hex avoids '$' headaches)
MCP_AUTH_TOKEN=

# DEV ONLY: serve with NO bearer check. Never on a shared/network deployment.
# MCP_DISABLE_AUTH=true

# Where to publish the port on the host. The MSSQL MCP server already uses
# 8000, so default this one to 8001 to avoid a clash on the same VM.
BIND_ADDR=0.0.0.0
HOST_PORT=8001

# --- Search API (defaults shown; override only if they change) ---------------
# Results/filtering endpoint (the real Typesense-backed product data).
# SEARCH_API_URL=https://api.sfsupplies.com/api/Products/Search/v2

# Typeahead/autocomplete endpoint (search-bar suggester).
# SUGGEST_API_URL=https://api.sfsupplies.com/api/Products/query

# Template for product page links. VERIFY this matches your real site path.
# PRODUCT_URL_TEMPLATE=https://www.sfsupplies.com/product/{slug}

# Optional, only if the search API is ever locked down:
# SEARCH_API_KEY=
# SEARCH_API_KEY_HEADER=Authorization
